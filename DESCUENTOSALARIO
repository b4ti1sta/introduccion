// CREAR UN PROGRAMA QUE CALCULE EL DESCUENTO DE UN 25% DE UN SALARIO DEVENGADO POR UN EMPLEADO, CAPTURA SU NOMBRE Y SALARIO.

PROCESO DESCUENTO
ESCRIBIR "PROGRAMA QUE TE DESCUENTA EL 25%"
ESCRIBIR "DIGITE SU SALARIO"
LEER NOMBRE
ESCRIBIR "DIGITE SU SALARIO"
LEER SALARIO
PORCENTAJE = SALARIO * 25 / 100 // ESTA LINNEA CALCULA EL PORCENTAJE
SALARIOTOTAL = SALARIO - PORCENTAJE 

SI SALARIOTOTAL > 1000000 ENTONCES 
ESCRIBIR " SU SALARIO ES MUY ALTO, USTEP GANA",SALARIOTOTAL
SINO
ESCRIBIR "SU SALARIO ES MENOR A UN MILLON, USTEP GANA",SALARIOTOTAL
FINSI
